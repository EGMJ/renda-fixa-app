# ============================================================
# Arquivo de exemplo de variáveis de ambiente do backend.
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o .env real no repositório git.
# ============================================================

# --- Banco de Dados MySQL ---
# Formato: mysql+mysqlconnector://usuario:senha@host:porta/nome_do_banco
MYSQL_USER=root
MYSQL_PASSWORD=senha_aqui
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=renda_fixa

# --- Segurança JWT ---
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_por_uma_chave_secreta_forte_de_pelo_menos_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
